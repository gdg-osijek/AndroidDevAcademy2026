//ZADATAK5
object TransactionLogger {
    fun log(message: String) {
        println(message)
    }
}

class BankAccount(val accountNumber: String) {

    var balance = 0.0

    init {
        totalAccounts++
        TransactionLogger.log("Kreiran racun: $accountNumber")
    }

    fun deposit(amount: Double) {
        if (amount > 0) {
            balance += amount
            TransactionLogger.log("Uplata $amount na $accountNumber. Stanje: $balance")
        } else {
            println("Neispravna uplata")
        }
    }

    fun withdraw(amount: Double) {
        if (amount > balance) {
            println("Nedovoljno sredstava")
        } else if (amount > 0) {
            balance -= amount
            TransactionLogger.log("Isplata $amount s $accountNumber. Stanje: $balance")
        } else {
            println("Neispravan iznos")
        }
    }

    companion object {
        var totalAccounts = 0
    }
}

fun zadatak5() {

    val account1 = BankAccount("12345")
    val account2 = BankAccount("54321")

    account1.deposit(900.0)
    account2.deposit(800.0)
    account1.withdraw(150.0)
    account2.withdraw(300.0)

    println("Stanje ${account1.accountNumber}: ${account1.balance}")
    println("Stanje ${account2.accountNumber}: ${account2.balance}")

    println("Ukupno racuna: ${BankAccount.totalAccounts}")
}
